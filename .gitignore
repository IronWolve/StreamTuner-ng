# ─── StreamTuner-ng .gitignore ───────────────────────────────────────────────
# Keeps build junk, fetched binaries, the upstream reference, and our internal
# design docs out of the public repo (DEV_NOTES lesson / DECISIONS D21).

# Python bytecode / packaging
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments (Linux dev + the Windows build venv)
.venv/
.venv-win/
venv/
env/

# PyInstaller build output
build/
dist/
*.spec

# Build / dev / run helper scripts + install notes are NOT published — the repo ships
# just the app code (streamtuner_ng/ + run.py) and requirements.txt. Binaries are built
# locally and attached to GitHub Releases.
build.py
*.sh
*.bat
BUILD_WINDOWS.txt

# Platform binaries we fetch per-OS, never commit (libmpv is ~100 MB)
*.dll
*.so
*.dylib
*.7z
*.zip

# local release archive — zipped binaries kept for reference; these go to GitHub Releases, not git
releases/

# Reference-only upstream source — never shipped or committed
reference/

# Internal working notes / design docs are NOT published — only the README and
# the user-facing guides ship. Every other *.md stays local; add "!NAME.md" to
# publish another one (e.g. a plugin-authoring guide).
*.md
!README.md
!THEME-HOWTO.md
!PLUGINS.md
!HISTORY.md

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/
