# StreamTuner-ng .gitignore
# Public repo allowlist: source, legal/notice, public plugin/theme docs,
# README/release notes, run launchers, requirements, and screenshots.
# Internal planning docs, reference source, build output, and fetched binaries stay local.

# Default-deny root clutter; unignore the public surface below.
/*
!/.gitignore
!/streamtuner_ng/
!/run.py
!/run.sh
!/run_windows.bat
!/requirements.txt
!/README.md
!/RELEASE.md
!/THEME-HOWTO.md
!/PLUGINS.md
!/LICENSE
!/NOTICE
!/screenshots/

# Python bytecode / packaging
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments (Linux dev + the Windows build venv)
.venv/
.venv-win/
venv/
env/

# PyInstaller build output
build/
dist/
*.spec

# Build / dev helper scripts + install notes are NOT published. Binaries are built
# locally and attached to GitHub Releases.
build.py
*.sh
!run.sh
*.bat
!run_windows.bat
BUILD_WINDOWS.txt

# Platform binaries we fetch per-OS, never commit (libmpv is ~100 MB)
*.dll
*.so
*.dylib
*.7z
*.zip

# local release archive — zipped binaries kept for reference; these go to GitHub Releases, not git
releases/

# Reference-only upstream source — never shipped or committed
reference/

# Internal working notes / design docs are NOT published.
*.md
!README.md
!RELEASE.md
!THEME-HOWTO.md
!PLUGINS.md

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/
